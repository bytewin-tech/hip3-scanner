# Scanner
HIP3_SCAN_VENUES=xyz,flx,vntl,hyna,km,abcd,cash,para
HIP3_SCAN_INTERVAL_SECONDS=10
HIP3_SCAN_OUTPUT_DIR=./output
HIP3_SCAN_TOP_N=20

# Paper trader
HIP3_PAPER_TRADER_ENABLED=true
HIP3_PAPER_STATE_PATH=./output/paper_trader_state_live_1000.json

# Live trader (real money)
# Set HIP3_LIVE_ENABLED=true to activate
# Set DRY_RUN=false (with actual keys below) to place real orders
HIP3_LIVE_ENABLED=false
HIP3_LIVE_DRY_RUN=true
HIP3_LIVE_STATE_PATH=./output/live_trader_state.json
HIP3_LIVE_REQUIRE_APPROVAL=false

# Hyperliquid API keys (required for live trading)
# Get these from https://app.hyperliquid.xyz — NEVER commit real keys
HIP3_HL_WALLET_ADDRESS=
HIP3_HL_SECRET_KEY_B64=
# For testnet trading:
# HIP3_HL_BASE_URL=https://api.hyperliquid-testnet.xyz
HIP3_HL_BASE_URL=https://api.hyperliquid.xyz

# Dry run toggle (overrides live_dry_run when set)
DRY_RUN=true
